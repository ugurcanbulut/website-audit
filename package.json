{
  "name": "ui-audit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker:build": "esbuild src/worker/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/worker.cjs --tsconfig=tsconfig.json --keep-names=false --external:playwright --external:lighthouse --external:sharp --external:@axe-core/playwright --external:@projectwallace/css-analyzer --external:htmlhint --external:ioredis --external:bullmq --external:postgres --external:drizzle-orm --external:@anthropic-ai/sdk --external:openai --external:zod",
    "worker:start": "node dist/worker.cjs",
    "worker": "npm run worker:build && npm run worker:start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
