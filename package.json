    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "photoswipe": "^5.4.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "react": "19.2.4",
