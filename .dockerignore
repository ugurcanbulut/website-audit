# Keep the Docker build context lean and keep secrets off the image.
**/node_modules
**/.next
.next/**
.git
.gitignore
**/.env
**/.env.local
**/.env.*.local
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/.DS_Store

# Screenshots from local dev
public/screenshots/*
!public/screenshots/.gitkeep

# TS build cache
tsconfig.tsbuildinfo
*.tsbuildinfo

# Editor
.vscode
.idea

# OS
.DS_Store
Thumbs.db

# Repo docs not needed at runtime
docs
.claude
